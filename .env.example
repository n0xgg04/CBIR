# ---- Postgres ----
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=cbir

# ---- Backend ----
DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/cbir
STORAGE_ROOT=/app/storage
CORS_ORIGINS=http://localhost:3000

# ---- Frontend ----
# Public (browser) URLs:
NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_BASE=ws://localhost:8000/ws
# Internal (container-to-container) URL used by Next.js server components:
INTERNAL_API_BASE=http://backend:8000/api/v1
